# =============================================================
# OpenRAG - Git Attributes
# =============================================================

# Graph seed files: text, line-diffable, no LFS
backend/graph_seed/**/*.jsonl text diff
backend/graph_seed/**/*.json text diff
backend/graph_seed/**/*.cypher text diff

# Prevent accidental binary commits in seed directory
backend/graph_seed/**/*.bin filter=lfs diff=lfs merge=lfs -text
backend/graph_seed/**/*.dump filter=lfs diff=lfs merge=lfs -text
backend/graph_seed/**/*.gz filter=lfs diff=lfs merge=lfs -text
