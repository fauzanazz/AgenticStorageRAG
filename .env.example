# ============================================================
# DriveRAG - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# All variables have sensible defaults for local development.
# ============================================================

# --- Application ---
APP_NAME="DriveRAG"
APP_VERSION="0.1.0"
DEBUG=true
ENVIRONMENT=development

# --- API ---
API_PREFIX="/api/v1"
ALLOWED_ORIGINS='["http://localhost:3000"]'

# --- Auth ---
# Allow open user registration. The code default is false (secure);
# set to true here for local development convenience.
REGISTRATION_ENABLED=true
# Set to true if the app runs behind a trusted reverse proxy (enables X-Forwarded-For for rate limiting)
RATE_LIMIT_TRUST_PROXY_HEADERS=false
FRONTEND_URL=http://localhost:3000
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
# Separate encryption key for stored secrets (API keys, OAuth tokens).
# Required in staging/production. Falls back to JWT_SECRET_KEY in development.
ENCRYPTION_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dingdong_rag

# --- Neo4j  ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=dingdongrag

# --- Redis ---
REDIS_URL=redis://localhost:16379/0

# --- LLM (LiteLLM) ---
# Primary: Alibaba Cloud DashScope (Qwen models)
DASHSCOPE_API_KEY=sk-your-dashscope-key
DEFAULT_MODEL=dashscope/qwen3-max
# Fallback: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-key
FALLBACK_MODEL=anthropic/claude-sonnet-4-20250514
# Optional: OpenAI (additional fallback)
OPENAI_API_KEY=sk-your-key
# Optional: Google Gemini (LLM + embeddings)
GEMINI_API_KEY=AIza-your-gemini-key
# Optional: OpenRouter (access 200+ models via a single API key)
OPENROUTER_API_KEY=sk-or-v1-your-key
# Cheap model for auto-generating chat session titles (requires OPENROUTER_API_KEY by default)
TITLE_MODEL=openrouter/openai/gpt-4.1-nano
# Set DEFAULT_MODEL=gemini/gemini-2.0-flash to use Gemini for KG extraction.
# Set DEFAULT_MODEL=gemini/gemini-2.0-flash and EMBEDDING_MODEL=gemini/text-embedding-004 for both.

# --- Embeddings ---
# LiteLLM model string used for generating vector embeddings.
# Examples:
#   text-embedding-3-small           (OpenAI, default)
#   gemini/text-embedding-004        (Google Gemini — requires GEMINI_API_KEY)
#   text-embedding-v3                (DashScope / Alibaba — requires DASHSCOPE_API_KEY)
EMBEDDING_MODEL=text-embedding-3-small

# --- Google Drive (read-only) ---
# Choose ONE of the two options below:
#
# Option 1: Service Account (production -- share folder with SA email)
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON=
#
# Option 2: OAuth2 (also used for "Sign in with Google" login)
# Create a Web Application OAuth client at https://console.cloud.google.com/apis/credentials
# For Drive-only: run `cd backend && uv run python -m app.scripts.google_auth` to get REFRESH_TOKEN
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
#
# Shared: default Drive folder to scan (optional)
GOOGLE_DRIVE_FOLDER_ID=

# --- Docker Compose (override defaults for non-dev) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dingdong_rag
NEO4J_PASSWORD=dingdong_dev

# --- File Upload ---
MAX_UPLOAD_SIZE_MB=50
UPLOAD_TTL_DAYS=7
